generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  forms     Form[]
  patients  Patient[]
  responses Response[]
}

model Patient {
  id             String      @id @default(uuid())
  name           String
  cpf            String?
  rg             String?
  email          String?
  phone          String?
  birthDate      DateTime?
  gender         String?
  maritalStatus  String?
  profession     String?
  
  // Endereço
  cep            String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?

  // Emergência
  emergencyName  String?
  emergencyPhone String?

  notes          String?
  isActive       Boolean     @default(true)
  inactivatedAt DateTime?
  psychologistId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  psychologist   User        @relation(fields: [psychologistId], references: [id])
  responses      Response[]
  shareLinks     ShareLink[]
  attachments    Attachment[]

  @@unique([email, psychologistId])
  @@unique([cpf, psychologistId])
}

model Attachment {
  id         String   @id @default(uuid())
  filename   String
  originalName String
  mimeType   String
  size       Int
  patientId  String
  uploadedBy String
  createdAt  DateTime @default(now())
  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  @@index([patientId])
}

model Form {
  id         String      @id @default(uuid())
  title      String
  code       String?
  type       String?     @default("Avaliação")
  validated  Boolean     @default(false)
  audiences  String[]    @default(["Adulto"])
  source     String?     @default("custom")
  schema     Json
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  creator    User        @relation(fields: [createdBy], references: [id])
  responses  Response[]
  shareLinks ShareLink[]
}

model ShareLink {
  id           String    @id @default(uuid())
  token        String    @unique
  formId       String
  patientName  String?
  patientEmail String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  active       Boolean   @default(true)
  patientId    String?
  form         Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient      Patient?  @relation(fields: [patientId], references: [id])
}

model Response {
  id        String   @id @default(uuid())
  formId    String
  userId    String?
  data      Json
  createdAt DateTime @default(now())
  patientId String?
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient   Patient? @relation(fields: [patientId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}
