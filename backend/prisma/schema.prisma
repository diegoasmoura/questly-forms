generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  forms     Form[]
  patients  Patient[]
  responses Response[]
}

model Patient {
  id             String      @id @default(uuid())
  name           String
  cpf            String?
  rg             String?
  email          String?
  phone          String?
  birthDate      DateTime?
  gender         String?
  maritalStatus  String?
  profession     String?
  
  // Endereço
  cep            String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?

  // Emergência
  emergencyName  String?
  emergencyPhone String?

  notes          String?
  isActive       Boolean     @default(true)
  inactivatedAt DateTime?

  // Agenda
  sessionTime     String?
  sessionDuration Int?
  sessionFrequency String?
  nextSession     DateTime?

  psychologistId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  psychologist   User        @relation(fields: [psychologistId], references: [id])
  responses      Response[]
  shareLinks     ShareLink[]
  attachments    Attachment[]
  appointments   Appointment[]
  attendances    Attendance[]
  payments       Payment[]

  @@unique([email, psychologistId])
  @@unique([cpf, psychologistId])
}

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  dayOfWeek       Int      // 0 (Dom) a 6 (Sab)
  time            String   // HH:mm
  duration      Int      // em minutos
  startDate     DateTime // Data de início (não permite retroativo)
  
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([patientId])
  @@index([psychologistId])
}

// Registro de presença/falta
model Attendance {
  id            String   @id @default(uuid())
  patientId     String
  date          DateTime // Data da sessão
  status       String   // "presente", "falta", "justificada"
  notes         String?  // Observações
  sessionTime   String?  // Horário da sessão naquele dia
  
  // Vínculo para reagendamentos em cadeia
  parentId       String?
  parent         Attendance?  @relation("RescheduleChain", fields: [parentId], references: [id], onDelete: Cascade)
  children       Attendance[] @relation("RescheduleChain")

  // Vínculo financeiro
  paymentId      String?
  payment        Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([patientId, date])
  @@index([patientId])
  @@index([psychologistId])
  @@index([date])
}

model Payment {
  id              String       @id @default(uuid())
  amount          Float
  paymentDate     DateTime
  method          String       @default("Pix") 
  receiptIssued   Boolean      @default(false)
  notes           String?
  
  // Anexo do Recibo
  receiptAttachmentId String?
  receiptAttachment   Attachment? @relation(fields: [receiptAttachmentId], references: [id])

  patientId       String
  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologistId  String

  attendances     Attendance[]
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([patientId])
  @@index([psychologistId])
  @@index([receiptAttachmentId])
}

model Attachment {
  id         String   @id @default(uuid())
  filename   String
  originalName String
  mimeType   String
  size       Int
  patientId  String
  uploadedBy String
  createdAt  DateTime @default(now())
  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  payments   Payment[]
  
  @@index([patientId])
}

model Form {
  id         String      @id @default(uuid())
  title      String
  code       String?
  type       String?     @default("Avaliação")
  validated  Boolean     @default(false)
  audiences  String[]    @default(["Adulto"])
  source     String?     @default("custom")
  schema     Json
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  creator    User        @relation(fields: [createdBy], references: [id])
  responses  Response[]
  shareLinks ShareLink[]
}

model ShareLink {
  id           String    @id @default(uuid())
  token        String    @unique
  formId       String
  patientName  String?
  patientEmail String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  active       Boolean   @default(true)
  patientId    String?
  form         Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient      Patient?  @relation(fields: [patientId], references: [id])
}

model Response {
  id        String   @id @default(uuid())
  formId    String
  userId    String?
  data      Json
  createdAt DateTime @default(now())
  patientId String?
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient   Patient? @relation(fields: [patientId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}
