generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  forms     Form[]
  patients  Patient[]
  responses Response[]
}

model Patient {
  id             String      @id @default(uuid())
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  notes          String?
  psychologistId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  psychologist   User        @relation(fields: [psychologistId], references: [id])
  responses      Response[]
  shareLinks     ShareLink[]

  @@unique([email, psychologistId])
}

model Form {
  id         String      @id @default(uuid())
  title      String
  schema     Json
  createdBy  String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  creator    User        @relation(fields: [createdBy], references: [id])
  responses  Response[]
  shareLinks ShareLink[]
}

model ShareLink {
  id           String    @id @default(uuid())
  token        String    @unique
  formId       String
  patientName  String?
  patientEmail String?
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  active       Boolean   @default(true)
  patientId    String?
  form         Form      @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient      Patient?  @relation(fields: [patientId], references: [id])
}

model Response {
  id        String   @id @default(uuid())
  formId    String
  userId    String?
  data      Json
  createdAt DateTime @default(now())
  patientId String?
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient   Patient? @relation(fields: [patientId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}
