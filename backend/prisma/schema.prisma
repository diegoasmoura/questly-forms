generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forms      Form[]
  responses  Response[]
  patients   Patient[]
}

model Patient {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  notes          String?  @db.Text
  psychologistId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  psychologist User       @relation(fields: [psychologistId], references: [id])
  responses    Response[]
  shareLinks   ShareLink[]

  @@unique([email, psychologistId])
}

model Form {
  id        String   @id @default(uuid())
  title     String
  schema    Json     // SurveyJS JSON schema
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator       User           @relation(fields: [createdBy], references: [id])
  shareLinks    ShareLink[]
  responses     Response[]
}

model ShareLink {
  id        String   @id @default(uuid())
  token     String   @unique // unique share token
  formId    String
  patientId String?
  patientName String?  // Keep for legacy/quick links
  patientEmail String? // Keep for legacy/quick links
  createdAt DateTime @default(now())
  expiresAt DateTime?
  active    Boolean  @default(true)

  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  patient   Patient? @relation(fields: [patientId], references: [id])
}

model Response {
  id        String   @id @default(uuid())
  formId    String
  userId    String?  // Psychologist id (if tested by them)
  patientId String?  // Linked patient
  data      Json     // SurveyJS response data
  createdAt DateTime @default(now())

  form    Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
  patient Patient? @relation(fields: [patientId], references: [id])
}
