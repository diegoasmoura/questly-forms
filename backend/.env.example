# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database"

# JWT - IMPORTANT: Change this to a strong random value in production
# Generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MINIMUM_32_CHARACTERS"

# Server
PORT=3001

# Allowed CORS Origins (comma separated)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:3005"
